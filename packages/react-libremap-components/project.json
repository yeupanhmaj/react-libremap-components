{
	"name": "react-libremap-components",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "packages/react-libremap-components/src",
	"projectType": "library",
	"tags": [],
	"// targets": "to see all targets run: nx show project react-libremap-components --web",
	"targets": {
		"pack": {
			"executor": "nx:run-commands",
			"dependsOn": ["build"],
			"options": {
				"command": "pnpm pack",
				"cwd": "packages/react-libremap-components"
			}
		},
		"storybook": {
			"executor": "nx:run-commands",
			"options": {
				"command": "storybook dev --port 4400 --config-dir .storybook",
				"cwd": "packages/react-libremap-components"
			}
		},
		"build-storybook": {
			"executor": "nx:run-commands",
			"options": {
				"command": "storybook build --config-dir .storybook --output-dir storybook-static",
				"cwd": "packages/react-libremap-components"
			}
		}
	}
}
